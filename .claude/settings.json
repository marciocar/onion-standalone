{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(ls .claude/*)",
      "Bash(grep * .env)",
      "Bash(wc -l *)",
      "Bash(find .claude *)",
      "Read",
      "Grep",
      "Glob"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f .env && p=$(grep -E \"^TASK_MANAGER_PROVIDER=\" .env | head -1 | cut -d= -f2 | tr -d \"[:space:]\") && printf '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"Onion: TASK_MANAGER_PROVIDER ativo = %s\"}}\\n' \"${p:-none}\" || true",
            "timeout": 5,
            "statusMessage": "Detectando Task Manager provider (Onion)"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/worklog-capture-session.sh\"",
            "timeout": 5,
            "statusMessage": "Capturando session_id no worklog (Onion)"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/co-evolution-inbox-check.sh\"",
            "timeout": 5,
            "statusMessage": "Checando inbox de co-evolução (Onion)"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-beacon-hook.sh\" up",
            "timeout": 5,
            "statusMessage": "Acendendo farol de sessão (Onion)"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-beacon-hook.sh\" refresh",
            "timeout": 5,
            "statusMessage": "Refrescando farol de sessão (Onion)"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-beacon-hook.sh\" down",
            "timeout": 5,
            "statusMessage": "Apagando farol de sessão (Onion)"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/worklog-precompact-breadcrumb.sh\"",
            "timeout": 5,
            "statusMessage": "Breadcrumb de compaction no worklog (Onion)"
          }
        ]
      }
    ]
  }
}
