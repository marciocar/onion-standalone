# ═══════════════════════════════════════════════════════════════════════════════
# 🧅 SISTEMA ONION - CONFIGURAÇÕES DE AMBIENTE
# ═══════════════════════════════════════════════════════════════════════════════
# Copie para .env e preencha os valores necessários
# ⚠️ NUNCA commite o arquivo .env com dados sensíveis!
#
# Documentação: docs/onion/getting-started.md
# Setup guiado: /meta/setup-integration
# ═══════════════════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════════════════════
# 🎯 GERENCIADOR DE TAREFAS (Principal)
# ═══════════════════════════════════════════════════════════════════════════════
# Provedor ativo para /product/task, /engineer/start, etc.
# Opções: jira | clickup | asana | linear | none
TASK_MANAGER_PROVIDER=jira

# Transporte do adapter (SDAAL): api (default, REST API) | mcp (opcional, quando o provider tem servidor MCP)
TASK_MANAGER_TRANSPORT=api


# ═══════════════════════════════════════════════════════════════════════════════
# 📋 JIRA (se TASK_MANAGER_PROVIDER=jira)  ← Default
# ═══════════════════════════════════════════════════════════════════════════════
# Suporta Jira Cloud (REST v3 + ADF) e Server/Data Center (REST v2)
#
# ─── OBRIGATÓRIAS ──────────────────────────────────────────────────────────────
# Hostname SEM https:// e SEM barra final
#   Cloud:      empresa.atlassian.net
#   Server/DC:  jira.empresa.com
JIRA_HOST=

# Email da conta Atlassian (Cloud com Basic Auth)
# Deixe vazio se usar JIRA_AUTH_TYPE=bearer (Server/DC com PAT)
JIRA_EMAIL=

# API Token (Cloud) ou Personal Access Token (Server/DC)
#   Cloud:      https://id.atlassian.com/manage-profile/security/api-tokens
#   Server/DC:  Profile > Personal Access Tokens (Jira 8.14+)
JIRA_API_TOKEN=

# ─── OPCIONAIS (recomendadas) ──────────────────────────────────────────────────
# Project key padrão para novas issues (ex: PROJ, DEV)
# Encontre em qualquer issue: URL termina em /browse/PROJ-123
JIRA_PROJECT_KEY=

# Tipo de autenticação
#   basic   — Cloud com email + API token (default)
#   bearer  — Server/DC com Personal Access Token
# JIRA_AUTH_TYPE=basic

# Versão da REST API
#   3 — Cloud (default, usa ADF e /search/jql com nextPageToken)
#   2 — Server/DC antigo (wiki markup e /search com startAt)
# JIRA_API_VERSION=3


# ═══════════════════════════════════════════════════════════════════════════════
# 📋 CLICKUP (se TASK_MANAGER_PROVIDER=clickup)
# ═══════════════════════════════════════════════════════════════════════════════
# Token: ClickUp > Settings > Apps > API Token
# CLICKUP_API_TOKEN=

# Workspace ID - detectado automaticamente se não informado
# Encontre em: URL do ClickUp (https://app.clickup.com/XXXXXXXX/...)
# CLICKUP_WORKSPACE_ID=

# Lista padrão para novas tasks (opcional)
# Encontre em: URL da lista (https://app.clickup.com/.../li/XXXXXXXX)
# CLICKUP_DEFAULT_LIST_ID=


# ═══════════════════════════════════════════════════════════════════════════════
# 📋 ASANA (se TASK_MANAGER_PROVIDER=asana)
# ═══════════════════════════════════════════════════════════════════════════════
# Token: Asana > My Settings > Apps > Developer Apps > Personal Access Token
# ASANA_ACCESS_TOKEN=

# Workspace e projeto padrão
# ASANA_WORKSPACE_ID=
# ASANA_DEFAULT_PROJECT_ID=


# ═══════════════════════════════════════════════════════════════════════════════
# 📋 LINEAR (se TASK_MANAGER_PROVIDER=linear)
# ═══════════════════════════════════════════════════════════════════════════════
# Token: Linear > Settings > API > Personal API Keys
# LINEAR_API_KEY=

# Team ID padrão
# LINEAR_TEAM_ID=


# ═══════════════════════════════════════════════════════════════════════════════
# 🐙 FORGE (Host de código remoto — PR, review, CI, Release)
# ═══════════════════════════════════════════════════════════════════════════════
# Abstração SDAAL: .claude/utils/forge/ (adapter-irmão do task-manager).
# Cobre SÓ operações de host remoto; git local (branch/merge/tag/push) é git direto.
#
# Provider e transporte (opcionais — se ausentes, detecta pelo remote / usa defaults):
FORGE_PROVIDER=github          # github | gitlab | bitbucket | none (default: detecta pelo remote)
FORGE_TRANSPORT=cli            # cli (default, gh CLI) | api (REST fallback via gh api/curl)
#
# --- Transporte de co-evolução (federation-transport SDAAL — RFC-0004 F2.1) ---
FEDERATION_TRANSPORT=git-async # git-async (default, doc-bridge) | local (carteiro same-machine) | a2a-live (GATED, stub) | auto
#   auto = local se o membro tem clone nesta máquina, senão git-async. a2a-live nunca é auto (gated: RFC-0004 fase-2).
#   Resolve via .claude/utils/federation-transport/detect-transport.sh <member-id>.
#
# a2a-live — gate de segurança do receptor (F2.2 FUNDAÇÃO no core; NENHUMA var obrigatória):
# A2A_JWKS_DIR=.claude/utils/federation-transport/jwks   # pubkeys PINADAS por kid (a2a-verify camada 5); offline
# A2A_CLOCK_SKEW=300                                       # tolerância (s) p/ iat futuro na janela de timestamp
#   ⚠️ O gate a2a-verify.sh NÃO faz rede (JWKS = fixture local). As vars do ENDPOINT VIVO (A2A_ENDPOINT_URL,
#      OAuth client/secret, mTLS) são FORA DE ESCOPO aqui — vivem no repo privado ~/onion-bridge da VPS (gated).
#
# Auth (condicional ao transporte):
#  - transport=cli: basta `gh auth login`; GH_TOKEN é alternativa
#  - transport=api: exige GH_TOKEN ou GITHUB_TOKEN
# Escopos necessários (token): repo, workflow, read:org
GH_TOKEN=                      # precedência sobre GITHUB_TOKEN; usado por gh e pela REST
GITHUB_TOKEN=                  # fallback de auth; também usado por automações Git/PR


# ═══════════════════════════════════════════════════════════════════════════════
# 🛡️ DE-IDENTIFICATION (Redação de PII antes de enviar ao orquestrador)
# ═══════════════════════════════════════════════════════════════════════════════
# Abstração SDAAL: .claude/utils/de-identification/ — primeira abstração cujo provider
# é um RUNTIME de inferência ("SLM como ferramenta", nunca como orquestrador).
# Unlock de compliance (LGPD/GDPR/HIPAA): o dado sensível é redigido LOCALMENTE.
#
DEID_PROVIDER=none             # none (fail-safe) | regex (determinístico, no core) | local-slm (no alvo)
#
# regex: sem credencial — PII de formato fixo (email/CPF/CNPJ/telefone/cartão/IPv4).
# local-slm (PII contextual: nomes/endereços/jurisdição — RODA NO ALVO, modelo não vive no core):
DEID_SLM_ENDPOINT=             # ex: http://localhost:11434 (estilo Ollama/vLLM)
DEID_SLM_MODEL=                # ex: llama3.2:3b (SLM pequeno 1–12B)
# DEID_SLM_TIMEOUT_MS=30000    # opcional
# none é FAIL-SAFE: sem provider, redact() recusa (avisa risco de PII) salvo override humano.


# ═══════════════════════════════════════════════════════════════════════════════
# 🎨 GAMMA.APP (Apresentações com IA)
# ═══════════════════════════════════════════════════════════════════════════════
# Token: gamma.app > Settings > API
GAMMA_API_KEY=


# ═══════════════════════════════════════════════════════════════════════════════
# 🤖 ANTHROPIC / CLAUDE (API + revisor de CI nativo)
# ═══════════════════════════════════════════════════════════════════════════════
# Key: https://console.anthropic.com/settings/keys
# Uso local/SDK. Para a GitHub Action onion-review.yml, configure TAMBÉM como
# secret do repositório (Settings > Secrets and variables > Actions) — o CI NÃO
# lê este .env (ele é gitignored e não chega ao runner).
ANTHROPIC_API_KEY=


# ═══════════════════════════════════════════════════════════════════════════════
# 🐘 POSTGRESQL (Banco de Dados)
# ═══════════════════════════════════════════════════════════════════════════════
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=


# ═══════════════════════════════════════════════════════════════════════════════
# 🔧 CONFIGURAÇÕES AVANÇADAS (Opcional)
# ═══════════════════════════════════════════════════════════════════════════════
# Nível de log: debug | info | warn | error
# LOG_LEVEL=info

# Timeout para chamadas de API (ms)
# API_TIMEOUT=30000

# Habilitar cache de contexto
# CONTEXT_CACHE_ENABLED=true
